---
interface Props {
  app: string;
  title: string;
  excerpt: string;
  href: string;
  cta: string;
}

const { app, title, excerpt, href, cta } = Astro.props;
---

<article class="post-card">
  <span class="app-name">{app}</span>
  <h3>{title}</h3>
  <p>{excerpt}</p>
  <p><a class="text-link" href={href}>{cta}</a></p>
</article>
