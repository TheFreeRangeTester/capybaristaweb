---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { copy, type Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = copy[lang];
---

<BaseLayout title={`${t.privacy.title} · Capybarista`} description={t.privacy.intro} lang={lang}>
  <div class="page">
    <Header lang={lang} labels={t.nav} />
    <main class="shell">
      <section class="page-title">
        <h1>{t.privacy.title}</h1>
        <p>{t.privacy.updated}</p>
      </section>
      <article class="content">
        <p>{t.privacy.intro}</p>
        {t.privacy.sections.map((section) => (
          <>
            <h2>{section.title}</h2>
            <p>{section.body}</p>
          </>
        ))}
      </article>
    </main>
    <Footer lang={lang} labels={t.nav} />
  </div>
</BaseLayout>
