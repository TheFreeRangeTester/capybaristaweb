---
interface Props {
  name: "LinkedIn" | "YouTube";
  href: string;
}

const { name, href } = Astro.props;
---

<a class="social-icon-link" href={href} target="_blank" rel="noreferrer" aria-label={name} title={name}>
  {
    name === "LinkedIn" ? (
      <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
        <path d="M6.94 8.9H3.56V20h3.38V8.9ZM7.22 5.46c0-1.04-.78-1.84-1.95-1.84-1.16 0-1.93.8-1.93 1.84 0 1.02.75 1.84 1.89 1.84h.02c1.19 0 1.97-.82 1.97-1.84ZM20.66 13.64c0-3.33-1.78-4.88-4.16-4.88-1.91 0-2.78 1.05-3.26 1.79V8.9H9.86c.04 1.04 0 11.1 0 11.1h3.38v-6.2c0-.33.02-.66.12-.9.27-.66.87-1.35 1.88-1.35 1.33 0 1.86 1.02 1.86 2.51V20h3.56v-6.36Z" />
      </svg>
    ) : (
      <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
        <path d="M21.58 7.19a2.78 2.78 0 0 0-1.95-1.97C17.91 4.75 12 4.75 12 4.75s-5.91 0-7.63.47a2.78 2.78 0 0 0-1.95 1.97A29.03 29.03 0 0 0 1.96 12c0 1.68.15 3.35.46 4.81a2.78 2.78 0 0 0 1.95 1.97c1.72.47 7.63.47 7.63.47s5.91 0 7.63-.47a2.78 2.78 0 0 0 1.95-1.97c.31-1.46.46-3.13.46-4.81 0-1.68-.15-3.35-.46-4.81ZM10.02 15.32V8.68L15.62 12l-5.6 3.32Z" />
      </svg>
    )
  }
  <span>{name}</span>
</a>
