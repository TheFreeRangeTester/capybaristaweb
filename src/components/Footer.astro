---
import SocialIconLink from "./SocialIconLink.astro";
import type { Locale } from "../i18n";

interface Props {
  lang: Locale;
  labels: {
    privacyPolicy: string;
  };
}

const { lang = "es", labels } = Astro.props;
const socials = [
  { name: "LinkedIn", href: "https://www.linkedin.com/in/patricio-m-690b3729/" },
  { name: "Instagram", href: "https://www.instagram.com/capybaristastudio/" },
] as const;
---

<footer class="site-footer">
  <div class="shell footer-inner">
    <span class="footer-brand">Capybarista · Apps for iOS</span>
    <nav class="footer-links" aria-label="Social links">
      <div class="footer-socials">
        {socials.map((social) => (
          <SocialIconLink name={social.name} href={social.href} />
        ))}
      </div>
      <a class="text-link" href={`/${lang}/privacy-policy/`}>{labels.privacyPolicy}</a>
    </nav>
  </div>
</footer>
