---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Header from "../../../../components/Header.astro";
import Footer from "../../../../components/Footer.astro";
import { copy, locales, type Locale } from "../../../../i18n";

type AppKey = "checkpoint" | "newen" | "daypeek";

export function getStaticPaths() {
  const appKeys = ["checkpoint", "newen", "daypeek"] as const;
  return locales.flatMap((lang) => appKeys.map((app) => ({ params: { lang, app } })));
}

const lang = Astro.params.lang as Locale;
const app = Astro.params.app as AppKey;
const t = copy[lang];
const appCopy = t.apps[app];
const checkpointSections = app === "checkpoint" ? t.apps.checkpoint.sections : null;
const newenSections = app === "newen" ? t.apps.newen.sections : null;
const daypeekSections = app === "daypeek" ? t.apps.daypeek.sections : null;
const appStoreHrefs: Record<AppKey, string> = {
  checkpoint: "https://apps.apple.com/nz/app/checkpoint-companion/id6766421117",
  newen: "https://apps.apple.com/nz/app/newen/id6765529178",
  daypeek: "https://apps.apple.com/nz/app/daypeek/id6779453761?mt=12",
};
const appStoreHref = appStoreHrefs[app];
const guideHref =
  app === "checkpoint"
    ? `/${lang}/blog/checkpoint/primer-checkpoint/`
    : app === "newen"
      ? `/${lang}/blog/newen/rutina-ligera/`
      : `/${lang}/blog/daypeek/ordenar-tu-dia/`;
const guideTitle =
  app === "checkpoint"
    ? t.posts.checkpoint.title
    : app === "newen"
      ? t.posts.newen.title
      : t.posts.daypeek.title;
---

<BaseLayout title={`${appCopy.name} · Capybarista`} description={appCopy.description} lang={lang}>
  <div class="page">
    <Header lang={lang} labels={t.nav} />
    <main class="shell">
      <section class="page-title">
        <h1>{appCopy.detailTitle}</h1>
        <p>{appCopy.detailIntro}</p>
        {
          appStoreHref && (
            <div class="page-title-actions">
              <a class="button" href={appStoreHref} target="_blank" rel="noreferrer">
                App Store
              </a>
            </div>
          )
        }
      </section>
      {
        checkpointSections ? (
          <article class="product-detail checkpoint-detail">
            <section class="product-intro">
              <div>
                <img class="product-logo" src="/checkpoint-logo.png" alt="" aria-hidden="true" />
                <h2>{appCopy.purposeTitle}</h2>
              </div>
              <p>{appCopy.purpose}</p>
            </section>

            <section class="product-section split">
              <div>
                <h2>{checkpointSections.storyTitle}</h2>
              </div>
              <div>
                {checkpointSections.storyBody.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </section>

            <section class="product-section split">
              <div>
                <h2>{checkpointSections.problemTitle}</h2>
                <p>{checkpointSections.problemText}</p>
              </div>
              <div class="feature-stack">
                {checkpointSections.problemItems.map((item) => (
                  <article class="feature-line">
                    <h3>{item.title}</h3>
                    <p>{item.body}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="product-section checkpoint-resume">
              <figure class="checkpoint-resume-visual">
                <img
                  src="/checkpoint-showcase.png"
                  alt={`${appCopy.name} ${t.appDirectory.screenshotAlt}`}
                  loading="lazy"
                  width="1200"
                  height="900"
                />
              </figure>
              <div>
                <h2>{checkpointSections.resumeTitle}</h2>
                <p>{checkpointSections.resumeText}</p>
                <ul class="check-list">
                  {checkpointSections.resumeItems.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </section>

            <section class="guide-band">
              <div>
                <h2>{t.apps.guidesTitle}</h2>
                <p>{guideTitle}</p>
              </div>
              <a class="button" href={guideHref}>{checkpointSections.guideCta}</a>
            </section>

            <section class="product-section compact-privacy">
              <h2>{t.apps.privacyTitle}</h2>
              <p>
                {t.apps.privacyText}
                <a href={`/${lang}/privacy-policy/`}>{t.nav.privacyPolicy}</a>.
              </p>
            </section>
          </article>
        ) : newenSections ? (
          <article class="product-detail newen-detail">
            <section class="product-intro newen-intro">
              <div>
                <h2>{appCopy.purposeTitle}</h2>
                <p>{appCopy.purpose}</p>
              </div>
              <figure class="newen-intro-visual">
                <img
                  src="/newen-showcase.png"
                  alt={`${appCopy.name} ${t.appDirectory.screenshotAlt}`}
                  loading="eager"
                  width="1536"
                  height="1024"
                />
              </figure>
            </section>

            <section class="product-section split">
              <div>
                <h2>{newenSections.rhythmTitle}</h2>
                <p>{newenSections.rhythmText}</p>
              </div>
              <div class="feature-stack">
                {newenSections.rhythmItems.map((item) => (
                  <article class="feature-line">
                    <h3>{item.title}</h3>
                    <p>{item.body}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class:list={["product-section", "privacy-feature", lang !== "es" && "privacy-feature-text"]}>
              <div class="privacy-copy">
                <h2>{newenSections.privacyTitle}</h2>
                <p>{newenSections.privacyText}</p>
                <ul class="check-list">
                  {newenSections.privacyPoints.map((point) => <li>{point}</li>)}
                </ul>
              </div>
              {
                lang === "es" && (
                  <figure class="privacy-visual">
                    <img
                      src={newenSections.privacyImage}
                      alt={newenSections.privacyImageAlt}
                      loading="lazy"
                      width="872"
                      height="1804"
                    />
                  </figure>
                )
              }
            </section>

            <section class="product-section watch-section">
              <div>
                <h2>{newenSections.watchTitle}</h2>
                <p>{newenSections.watchText}</p>
              </div>
              <ul class="watch-list">
                {newenSections.watchItems.map((item) => <li>{item}</li>)}
              </ul>
            </section>

            <section class="guide-band">
              <div>
                <h2>{t.apps.guidesTitle}</h2>
                <p>{guideTitle}</p>
              </div>
              <a class="button" href={guideHref}>{newenSections.guideCta}</a>
            </section>

            <section class="product-section compact-privacy">
              <h2>{t.apps.privacyTitle}</h2>
              <p>
                {t.apps.privacyText}
                <a href={`/${lang}/privacy-policy/`}>{t.nav.privacyPolicy}</a>.
              </p>
            </section>
          </article>
        ) : daypeekSections ? (
          <article class="product-detail daypeek-detail">
            <section class="product-intro daypeek-intro">
              <div>
                <img class="product-logo" src="/daypeek-logo.svg" alt="" aria-hidden="true" />
                <h2>{appCopy.purposeTitle}</h2>
                <p>{appCopy.purpose}</p>
              </div>
              <figure class="daypeek-intro-visual">
                <img
                  src="/daypeek-showcase.png"
                  alt={`${appCopy.name} ${t.appDirectory.screenshotAlt}`}
                  loading="eager"
                  width="1536"
                  height="1024"
                />
              </figure>
            </section>

            <section class="product-section split">
              <div>
                <h2>{daypeekSections.glanceTitle}</h2>
                <p>{daypeekSections.glanceText}</p>
              </div>
              <div class="feature-stack">
                {daypeekSections.glanceItems.map((item) => (
                  <article class="feature-line">
                    <h3>{item.title}</h3>
                    <p>{item.body}</p>
                  </article>
                ))}
              </div>
            </section>

            <section class="product-section daypeek-guide">
              <div>
                <h2>{daypeekSections.guideTitle}</h2>
                <p>{daypeekSections.guideText}</p>
              </div>
              <ul class="check-list">
                {daypeekSections.guideItems.map((item) => <li>{item}</li>)}
              </ul>
            </section>

            <section class="guide-band">
              <div>
                <h2>{t.apps.guidesTitle}</h2>
                <p>{guideTitle}</p>
              </div>
              <a class="button" href={guideHref}>{daypeekSections.guideCta}</a>
            </section>

            <section class="product-section compact-privacy">
              <h2>{t.apps.privacyTitle}</h2>
              <p>
                {t.apps.privacyText}
                <a href={`/${lang}/privacy-policy/`}>{t.nav.privacyPolicy}</a>.
              </p>
            </section>
          </article>
        ) : (
          <article class="content">
            <h2>{appCopy.purposeTitle}</h2>
            <p>{appCopy.purpose}</p>
            <h2>{t.apps.guidesTitle}</h2>
            <p><a href={guideHref}>{guideTitle}</a></p>
            <h2>{t.apps.privacyTitle}</h2>
            <p>
              {t.apps.privacyText}
              <a href={`/${lang}/privacy-policy/`}>{t.nav.privacyPolicy}</a>.
            </p>
          </article>
        )
      }
    </main>
    <Footer lang={lang} labels={t.nav} />
  </div>
</BaseLayout>
