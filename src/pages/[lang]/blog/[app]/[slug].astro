---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Header from "../../../../components/Header.astro";
import Footer from "../../../../components/Footer.astro";
import { copy, locales, type Locale } from "../../../../i18n";

export function getStaticPaths() {
  const posts = [
    { app: "checkpoint", slug: "primer-checkpoint" },
    { app: "newen", slug: "rutina-ligera" },
  ] as const;

  return locales.flatMap((lang) =>
    posts.map((post) => ({ params: { lang, app: post.app, slug: post.slug } })),
  );
}

const lang = Astro.params.lang as Locale;
const postKey = Astro.params.app as "checkpoint" | "newen";
const t = copy[lang];
const post = t.posts[postKey];
---

<BaseLayout title={`${post.title} · Capybarista`} description={post.excerpt} lang={lang}>
  <div class="page">
    <Header lang={lang} labels={t.nav} />
    <main class="shell">
      <section class="page-title">
        <h1>{post.title}</h1>
        <p>{post.intro}</p>
      </section>
      <article class="content">
        {post.sections.map((section) => (
          <>
            <h2>{section.title}</h2>
            <p>{section.body}</p>
          </>
        ))}
      </article>
    </main>
    <Footer lang={lang} labels={t.nav} />
  </div>
</BaseLayout>
