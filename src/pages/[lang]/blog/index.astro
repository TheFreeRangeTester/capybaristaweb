---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import PostCard from "../../../components/PostCard.astro";
import { copy, locales, type Locale } from "../../../i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = copy[lang];
---

<BaseLayout title={`${t.blogIndex.title} · Capybarista`} description={t.blogIndex.intro} lang={lang}>
  <div class="page">
    <Header lang={lang} labels={t.nav} />
    <main class="shell">
      <section class="page-title">
        <h1>{t.blogIndex.title}</h1>
        <p>{t.blogIndex.intro}</p>
      </section>

      <section class="blog-grid page-list" aria-label={t.blogIndex.title}>
        <PostCard
          app="Checkpoint"
          title={t.posts.checkpoint.title}
          href={`/${lang}/blog/checkpoint/primer-checkpoint/`}
          excerpt={t.posts.checkpoint.excerpt}
          cta={t.home.readGuide}
        />
        <PostCard
          app="Newen"
          title={t.posts.newen.title}
          href={`/${lang}/blog/newen/rutina-ligera/`}
          excerpt={t.posts.newen.excerpt}
          cta={t.home.readGuide}
        />
      </section>
    </main>
    <Footer lang={lang} labels={t.nav} />
  </div>
</BaseLayout>
