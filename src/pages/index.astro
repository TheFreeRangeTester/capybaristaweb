---
const defaultPath = "/es/";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${defaultPath}`} />
    <title>Capybarista</title>
    <script is:inline>
      const preferredLocale = navigator.languages?.some((language) => language.toLowerCase().startsWith("en"))
        ? "en"
        : "es";

      window.location.replace(`/${preferredLocale}/`);
    </script>
  </head>
  <body></body>
</html>
